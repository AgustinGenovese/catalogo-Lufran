<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <title>Panel — Lufran</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/estilos.css">
  <style>
    body {
      background: var(--clr-white);
      padding: 2rem;
    }

    h1 {
      text-align: center;
      color: var(--clr-text);
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 2rem;
      letter-spacing: -0.5px;
    }

    .panel-layout {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 2rem;
      align-items: start;
      max-width: 1200px;
      margin: 0 auto;
    }

    form {
      background: var(--clr-card);
      padding: 1.5rem;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
    }

    form label {
      display: block;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--clr-text);
      margin-bottom: 0.3rem;
    }

    form input,
    form textarea {
      width: 100%;
      padding: 0.65rem 0.75rem;
      margin-bottom: 1rem;
      border: 1px solid var(--clr-gray);
      border-radius: 8px;
      font-size: 0.9rem;
      font-family: inherit;
      transition: var(--transition);
    }

    form input:focus,
    form textarea:focus {
      outline: none;
      border-color: var(--clr-main-light);
      box-shadow: 0 0 0 3px rgba(184,145,101,0.15);
    }

    form textarea {
      resize: vertical;
      min-height: 60px;
    }

    .btn-group {
      display: flex;
      gap: 0.75rem;
      margin-top: 0.5rem;
    }

    .btn-group button {
      flex: 1;
      padding: 0.65rem;
      border: 0;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.85rem;
      cursor: pointer;
      transition: var(--transition);
    }

    #btnAgregar {
      background: var(--clr-main);
      color: #fff;
    }
    #btnAgregar:hover { background: #1a1a1a; }

    #btnAceptar {
      background: var(--clr-main-light);
      color: #fff;
    }
    #btnAceptar:hover { background: #a37d55; }

    #btnAgregar:disabled,
    #btnAceptar:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    .panel-links {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      margin-top: 1.25rem;
      font-size: 0.85rem;
    }

    .panel-links a {
      color: var(--clr-text-light);
      transition: var(--transition);
    }
    .panel-links a:hover {
      color: var(--clr-text);
    }

    .table-wrap {
      background: var(--clr-card);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
      overflow-x: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
    }

    th {
      text-align: left;
      padding: 0.75rem 1rem;
      background: var(--clr-gray);
      color: var(--clr-text);
      font-weight: 600;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    td {
      padding: 0.65rem 1rem;
      border-bottom: 1px solid var(--clr-gray);
      color: var(--clr-text);
    }

    td img {
      width: 44px;
      height: 44px;
      object-fit: cover;
      border-radius: 6px;
    }

    .acciones {
      display: flex;
      gap: 0.5rem;
    }

    .acciones button {
      padding: 0.4rem 0.75rem;
      border: 0;
      border-radius: 6px;
      font-size: 0.8rem;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
    }

    button.editar {
      background: var(--clr-gray);
      color: var(--clr-text);
    }
    button.editar:hover { background: #d6d0c8; }

    button.eliminar {
      background: var(--clr-red);
      color: #fff;
    }
    button.eliminar:hover { background: #c23d3d; }

    @media (max-width: 768px) {
      body { padding: 1rem; }
      .panel-layout { grid-template-columns: 1fr; }
    }
  </style>
</head>

<body>
  <h1>Gestión de Productos</h1>

  <div class="panel-layout">
    <div>
      <form id="formProducto" action="/api/productos" method="POST">
        <label for="nombre">Nombre</label>
        <input type="text" id="nombre" name="nombre" required>

        <label for="descripcion">Descripción</label>
        <textarea id="descripcion" name="descripcion"></textarea>

        <label for="imagen">URL de imagen</label>
        <input type="url" id="imagen" name="imagen" placeholder="https://...">

        <label for="categoria">Categoría</label>
        <input type="text" id="categoria" name="categoria" required>

        <label for="precio">Precio</label>
        <input type="text" id="precio" name="precio" required>

        <div class="btn-group">
          <button id="btnAgregar" type="submit">Agregar</button>
          <button id="btnAceptar" type="button" disabled>Aceptar</button>
        </div>

        <div class="panel-links">
          <a href="/">← Volver al inicio</a>
          <a href="/logout">Cerrar sesión</a>
        </div>
      </form>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Cat.</th>
            <th>Precio</th>
            <th>Img</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody id="productosBody"></tbody>
      </table>
    </div>
  </div>

  <script>
    const form = document.querySelector('#formProducto');
    const btnAgregar = document.getElementById('btnAgregar');
    const btnAceptar = document.getElementById('btnAceptar');

    const cargarProductos = () => {
      fetch('/api/productos')
        .then(res => res.json())
        .then(productos => {
          const tbody = document.getElementById('productosBody');
          tbody.innerHTML = '';

          productos.forEach(producto => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
              <td>${producto.nombre}</td>
              <td>${producto.categoria}</td>
              <td>$${producto.precio}</td>
              <td><img src="${producto.imagen || ''}" alt="${producto.nombre}"></td>
              <td>
                <div class="acciones">
                  <button class="editar" data-id="${producto._id}">Editar</button>
                  <button class="eliminar" data-id="${producto._id}">Eliminar</button>
                </div>
              </td>
            `;
            tbody.appendChild(tr);
          });

          document.querySelectorAll('button.eliminar').forEach(btn => {
            btn.addEventListener('click', () => {
              const id = btn.getAttribute('data-id');
              fetch(`/api/productos/${id}`, { method: 'DELETE' })
                .then(res => res.json())
                .then(() => cargarProductos())
                .catch(err => console.error(err));
            });
          });

          document.querySelectorAll('button.editar').forEach(btn => {
            btn.addEventListener('click', () => {
              const id = btn.getAttribute('data-id');
              fetch(`/api/productos/id/${id}`)
                .then(res => res.json())
                .then(producto => {
                  document.getElementById('nombre').value = producto.nombre;
                  document.getElementById('descripcion').value = producto.descripcion || '';
                  document.getElementById('imagen').value = producto.imagen || '';
                  document.getElementById('categoria').value = producto.categoria;
                  document.getElementById('precio').value = producto.precio;

                  let hiddenId = document.getElementById('productoId');
                  if (!hiddenId) {
                    hiddenId = document.createElement('input');
                    hiddenId.type = 'hidden';
                    hiddenId.id = 'productoId';
                    hiddenId.name = 'id';
                    form.appendChild(hiddenId);
                  }
                  hiddenId.value = producto._id;

                  btnAgregar.disabled = true;
                  btnAceptar.disabled = false;
                })
                .catch(err => console.error(err));
            });
          });
        });
    };

    btnAceptar.addEventListener('click', (e) => {
      e.preventDefault();
      const id = document.getElementById('productoId').value;

      const data = {
        nombre: document.getElementById('nombre').value,
        descripcion: document.getElementById('descripcion').value,
        imagen: document.getElementById('imagen').value,
        categoria: document.getElementById('categoria').value,
        precio: document.getElementById('precio').value
      };

      fetch(`/api/productos/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
        .then(res => res.json())
        .then(() => {
          form.reset();
          document.getElementById('productoId').remove();
          btnAgregar.disabled = false;
          btnAceptar.disabled = true;
          cargarProductos();
        })
        .catch(err => console.error(err));
    });

    btnAgregar.disabled = false;
    btnAceptar.disabled = true;

    cargarProductos();
  </script>

</body>

</html>